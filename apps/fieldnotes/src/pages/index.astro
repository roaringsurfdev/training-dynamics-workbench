---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="MIScope Fieldnotes" description="Research notes on mechanistic interpretability and transformer training dynamics.">
  <p style="color: var(--color-text-secondary); font-family: var(--font-ui); font-size: 0.95rem; margin-bottom: 2.5rem;">
    Research notes on mechanistic interpretability and transformer training dynamics.
    Work in progress, shared as it develops.
  </p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <div class="post-date">{formatDate(post.data.date)}</div>
        <div class="post-title">
          <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`}>{post.data.title}</a>
        </div>
        {post.data.description && (
          <div class="post-description">{post.data.description}</div>
        )}
      </li>
    ))}
  </ul>
</Base>
