---
/**
 * VariantViewer — tab-based switcher for per-variant Plotly figures.
 *
 * Usage in MDX:
 *   import VariantViewer from '../../components/VariantViewer.astro';
 *
 *   <VariantViewer
 *     variants={[
 *       { label: "p113 / seed=999 / ds=598", figures: [{ file: "multistream_p113_s999_ds598.html", height: 1350 }] },
 *       { label: "p109 / seed=485 / ds=598", figures: [{ file: "multistream_p109_s485_ds598.html", height: 1350 }] },
 *     ]}
 *     caption="Optional figure caption."
 *   />
 *
 * All figure files are resolved relative to fieldnotes/public/figures/.
 * The base URL from astro.config.mjs is applied automatically.
 */

interface FigureSpec {
  file: string;  // filename within fieldnotes/public/figures/
  height: number;
  title?: string;
}

interface VariantSpec {
  label: string;
  figures: FigureSpec[];
}

interface Props {
  variants: VariantSpec[];
  caption?: string;
}

const { variants, caption } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="variant-viewer">
  <div class="variant-tabs" role="tablist">
    {variants.map((v, i) => (
      <button
        class={`variant-tab${i === 0 ? " active" : ""}`}
        role="tab"
        aria-selected={i === 0 ? "true" : "false"}
        data-index={i}
      >
        {v.label}
      </button>
    ))}
  </div>

  {variants.map((v, i) => (
    <div
      class={`variant-panel${i === 0 ? "" : " hidden"}`}
      role="tabpanel"
      data-index={i}
    >
      {v.figures.map((f) => (
        <iframe
          src={`${base}/figures/${f.file}`}
          title={f.title ?? `${v.label} — ${f.file}`}
          width="100%"
          height={f.height}
          loading="lazy"
          style="border: none; display: block;"
        />
      ))}
    </div>
  ))}

  {caption && <p class="variant-caption">{caption}</p>}
</div>

<style>
  .variant-viewer {
    margin: 2.5rem 0;
    max-width: var(--wide-width);
    margin-left: calc(50% - var(--wide-width) / 2);
    margin-right: calc(50% - var(--wide-width) / 2);
  }

  .variant-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .variant-tab {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--color-border);
    background: white;
    cursor: pointer;
    border-radius: 3px;
    color: var(--color-text-secondary);
    transition: background 0.1s, color 0.1s;
  }

  .variant-tab:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .variant-tab.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .variant-panel.hidden {
    display: none;
  }

  .variant-caption {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    line-height: 1.5;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".variant-viewer").forEach((viewer) => {
    const tabs = viewer.querySelectorAll<HTMLButtonElement>(".variant-tab");
    const panels = viewer.querySelectorAll<HTMLElement>(".variant-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.index;

        tabs.forEach((t) => {
          t.classList.remove("active");
          t.setAttribute("aria-selected", "false");
        });
        panels.forEach((p) => p.classList.add("hidden"));

        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");
        viewer
          .querySelector<HTMLElement>(`.variant-panel[data-index="${target}"]`)
          ?.classList.remove("hidden");
      });
    });
  });
</script>
